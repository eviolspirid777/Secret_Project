# Игнорировать bin и obj во всех микросервисах (ключевое правило!)
**/bin/
**/obj/
**/[Bb]in/
**/[Oo]bj/

# Игнорировать папки сборки во всех проектах
**/[Dd]ebug/
**/[Rr]elease/
**/x64/
**/build/
**/AppPackages/

# Игнорировать специфичные для проекта папки если они есть
**/pkg/
**/lib/
**/Generated/
**/generated/
**/Generated_Code/
**/_Pvt_Extensions/

# ======================================================
# ФАЙЛЫ ПОЛЬЗОВАТЕЛЯ VISUAL STUDIO
# ======================================================

# Файлы пользователя
*.suo
*.user
*.userprefs
*.sln.docstates

# Папка Visual Studio
.vs/
**/.vs/

# ======================================================
# РЕЗУЛЬТАТЫ СБОРКИ
# ======================================================

# Сгенерированные файлы сборки
*.dll
*.exe
*.pdb
*.so
*.dylib
*.ilk
*.meta
*.obj
*.pch
*.pgc
*.pgd
*.rsp
*.sbr
*.tlb
*.tli
*.tlh
*.tmp
*.tmp_proj

# Логи сборки
*.log
*.[Ll]og
[Bb]uild[Ll]og.*

# ======================================================
# РЕЗУЛЬТАТЫ ТЕСТИРОВАНИЯ
# ======================================================

[Tt]est[Rr]esult*/
**/[Tt]est[Rr]esult*/

# ======================================================
# NUGET ПАКЕТЫ
# ======================================================

# Папка packages
packages/
**/packages/

# Не игнорировать папку build внутри NuGet пакетов (нужно для сборки)
!packages/*/build/
!**/packages/*/build/

# Файлы блокировки пакетов
project.lock.json
**/project.lock.json
project.fragment.lock.json
**/project.fragment.lock.json

